# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# DeepSeek API (required for AI predictions)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# API-Football (required for match data)
API_FOOTBALL_KEY=your-api-football-key

# The Odds API (required for betting markets)
ODDS_API_KEY=your-odds-api-key

# Cron secret (protects cron endpoints from unauthorized invocation)
CRON_SECRET=your-generated-cron-secret

# App URL (used for OAuth redirects and canonical URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000
